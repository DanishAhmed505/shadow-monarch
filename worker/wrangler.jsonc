{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "shadow-monarch-reactions",
  "main": "src/index.js",
  "compatibility_date": "2026-07-01",
  "durable_objects": {
    "bindings": [
      { "name": "POST_REACTIONS", "class_name": "PostReactions" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["PostReactions"] }
  ],
  "observability": { "enabled": true }
}
